# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_APP_URL=http://localhost:8080

# Sentry Error Tracking
# Get this from https://sentry.io after creating a project
# Format: https://xxxxxxxxxxxx@o0000000.ingest.sentry.io/0000000
VITE_SENTRY_DSN=

# App Version (optional, for release tracking in Sentry)
VITE_APP_VERSION=1.0.0

# Server-only Edge Function secrets belong in Supabase secret storage, never in
# a VITE_ variable or committed file. Examples: SUPABASE_SERVICE_ROLE_KEY,
# PODSCAN_API_KEY, OPENAI_API_KEY, RESEND_API_KEY, ANTHROPIC_API_KEY,
# ONBOARDING_CAPABILITY_SECRET, APP_URL/WEB_URL,
# and Google credentials. See docs/workspace-onboarding.md for onboarding.

# Local diagnostic scripts only. Never commit real client identifiers.
DIAGNOSTIC_CLIENT_ID=
DIAGNOSTIC_CLIENT_EMAIL=
